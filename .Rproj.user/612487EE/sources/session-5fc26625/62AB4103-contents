\name{collectLegend}
\alias{collectLegend}
\title{Extract a ggplot legend as a new grob.}
\usage{
collectLegend(p)
}
\description{Extract a ggplot legend as a new grob.}
\arguments{
\item{p}{\code{grob}, output from PlotPolygons().}
}
\value{
Returns a grob containing only the legend from an input grob.
}
\examples{
# leg <- collectLegend(plot)
}


